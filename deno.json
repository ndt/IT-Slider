{
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-run --allow-env npm:typescript/bin/tsc src/app.ts src/domain.ts src/config.ts --outDir dist --target ESNext --module ESNext --moduleResolution Node --strict --skipLibCheck --esModuleInterop",
    "bundle": "deno run --allow-read --allow-write scripts/bundle.ts",
    "bundle-min": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run scripts/bundle_min.ts",
    "check": "deno run --allow-read scripts/check_integrity.ts",
    "test": "deno test --allow-read src/domain.test.ts"
  },
  "imports": {
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/expect": "jsr:@std/expect@^1.0.0",
    "terser": "npm:terser@^5.30.0",
    "clean-css": "npm:clean-css@^5.3.3",
    "html-minifier-terser": "npm:html-minifier-terser@^7.2.0"
  }
}
